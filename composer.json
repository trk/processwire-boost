{
  "name": "trk/processwire-boost",
  "description": "AI context bridge for ProcessWire CMS.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.3",
    "trk/processwire-console": "dev-main"
  },
  "autoload": {
    "psr-4": {
      "Totoglu\\ProcessWire\\Boost\\": "src/"
    }
  },
  "extra": {
    "processwire-console": {
      "commands": [
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostInstallCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\McpCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildGuidesCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildSkillsCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostScanCoreCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostScanModulesCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostScanAllCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildBlueprintsCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildAllCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildCoreCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostBuildModulesCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostAssertCommand",
        "Totoglu\\ProcessWire\\Boost\\Console\\Commands\\BoostVersionCommand"
